<footer class="footer">
  <div class="footer-inner">
    <p class="font-script footer-quote">
      "Mientras exista este sitio, siempre habrá un lugar donde nosotros seguimos pasando."
    </p>
    <div class="divider"></div>
    <p class="footer-year">Hecho con amor · {new Date().getFullYear()}</p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    padding: 4rem 1.5rem;
    text-align: center;
    border-top: 1px solid rgba(184, 159, 212, 0.08);
  }

  .footer-inner { max-width: 40rem; margin: 0 auto; }

  .footer-quote {
    font-size: 1.25rem;
    color: var(--color-cream-dim);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .footer-year {
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
